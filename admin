import { atom } from 'recoil';
import type { AdminConfigEntry } from '../schemas/adminConfig';
import { MOCK_ADMIN_CONFIG } from '../mocks/admin-config-fixtures';

// Dev mock — populated by GET /admin/config/all in production (see src/api/creditSummaryApi.ts for the call pattern to follow).
export const adminConfigAtom = atom<AdminConfigEntry[]>({
  key: 'adminConfigState',
  default: MOCK_ADMIN_CONFIG,
});


export interface AdminConfigEntry {
  key: string;
  value: string;
  updated_by: string;
  updated_on: string; // ISO 8601
}



import { useCallback } from 'react';
import { useRecoilState } from 'recoil';
import { adminConfigAtom } from '../state/adminConfigAtom';

/** Provides the config table + an update action — simulates the POST /admin/config/{key} round trip locally. */
export function useAdminConfig() {
  const [entries, setEntries] = useRecoilState(adminConfigAtom);

  const updateValue = useCallback(
    (key: string, value: string, updatedBy: string) => {
      setEntries((rows) =>
        rows.map((row) =>
          row.key === key
            ? { ...row, value, updated_by: updatedBy, updated_on: new Date().toISOString() }
            : row
        )
      );
    },
    [setEntries],
  );

  return { entries, updateValue };
}


