import { useEffect, useState } from 'react';
import { Button, X } from '../../primitives';
import type { AdminConfigEntry } from '../../schemas/adminConfig';
import './EditConfigModal.css';

interface EditConfigModalProps {
  entry: AdminConfigEntry;
  onCancel: () => void;
  onSave: (value: string) => void;
}

export function EditConfigModal({ entry, onCancel, onSave }: EditConfigModalProps) {
  const [draftValue, setDraftValue] = useState(entry.value);

  useEffect(() => {
    const handleKey = (e: KeyboardEvent) => {
      if (e.key === 'Escape') onCancel();
    };
    window.addEventListener('keydown', handleKey);
    return () => window.removeEventListener('keydown', handleKey);
  }, [onCancel]);

  return (
    <>
      <div className="edit-config-scrim" onClick={onCancel} aria-hidden="true" />
      <div className="edit-config-modal" role="dialog" aria-label={`Edit ${entry.key}`}>
        <div className="edit-config-modal__header">
          <span>Edit config value</span>
          <button className="edit-config-modal__close" onClick={onCancel} aria-label="Close">
            <X size={16} />
          </button>
        </div>
        <div className="edit-config-modal__body">
          <label className="edit-config-modal__label">Key</label>
          <div className="edit-config-modal__key mono">{entry.key}</div>
          <label className="edit-config-modal__label" htmlFor="edit-config-value">Value</label>
          <textarea
            id="edit-config-value"
            className="edit-config-modal__textarea"
            value={draftValue}
            onChange={(e) => setDraftValue(e.target.value)}
            autoFocus
            spellCheck={false}
          />
        </div>
        <div className="edit-config-modal__footer">
          <Button variant="ghost" onClick={onCancel}>Cancel</Button>
          <Button variant="primary" onClick={() => onSave(draftValue)}>Save</Button>
        </div>
      </div>
    </>
  );
}


