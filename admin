import { useState } from 'react';
import { useRecoilValue } from 'recoil';
import { Search, Pencil } from '../../primitives';
import { useAdminConfig } from '../../hooks/useAdminConfig';
import { useUi } from '../../hooks/useUi';
import { userAtom } from '../../state/userAtom';
import { EditConfigModal } from './EditConfigModal';
import type { AdminConfigEntry } from '../../schemas/adminConfig';
import './AdminConfigPage.css';

function formatDate(iso: string): { date: string; time: string } {
  const d = new Date(iso);
  return {
    date: d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }),
    time: d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) + ' UTC',
  };
}

export function AdminConfigPage() {
  const { entries, updateValue } = useAdminConfig();
  const { showToast } = useUi();
  const user = useRecoilValue(userAtom);
  const [searchQuery, setSearchQuery] = useState('');
  const [editingEntry, setEditingEntry] = useState<AdminConfigEntry | null>(null);

  const filteredEntries = entries.filter((entry) =>
    entry.key.toLowerCase().includes(searchQuery.toLowerCase())
  );

  const handleSave = (value: string) => {
    if (!editingEntry) return;
    updateValue(editingEntry.key, value, `${user.firstName} ${user.lastName}`);
    showToast(`${editingEntry.key} updated`);
    setEditingEntry(null);
  };

  return (
    <div className="admin-config">
      {/* Header */}
      <header className="admin-config__header">
        <div>
          <div className="admin-config__eyebrow">ADMIN</div>
          <h1 className="admin-config__title">Configuration management</h1>
          <p className="admin-config__lead">
            Application configuration keys and their current values. Changes take effect immediately.
          </p>
        </div>
      </header>

      {/* Toolbar */}
      <div className="admin-config__toolbar">
        <div className="admin-config__search-wrap">
          <Search size={16} className="admin-config__search-icon" />
          <input
            className="admin-config__search"
            type="text"
            placeholder="Search by key…"
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
          />
        </div>
      </div>

      {/* Table */}
      <div className="admin-config__table-wrap">
        <table className="admin-config__table">
          <thead>
            <tr>
              <th>Key</th>
              <th>Value</th>
              <th>Updated by</th>
              <th>Updated on</th>
              <th aria-label="Edit"></th>
            </tr>
          </thead>
          <tbody>
            {filteredEntries.map((entry) => {
              const { date, time } = formatDate(entry.updated_on);
              return (
                <tr key={entry.key} className="admin-config__row">
                  <td><span className="mono">{entry.key}</span></td>
                  <td className="admin-config__value-cell">
                    <span className="mono">{entry.value}</span>
                  </td>
                  <td>{entry.updated_by}</td>
                  <td>{date}<br /><span className="muted">{time}</span></td>
                  <td className="right">
                    <button
                      className="admin-config__icon-btn"
                      onClick={() => setEditingEntry(entry)}
                      aria-label={`Edit ${entry.key}`}
                    >
                      <Pencil size={14} />
                    </button>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {/* Footer */}
      <div className="admin-config__footer">
        <span className="muted">Showing {filteredEntries.length} of {entries.length}</span>
      </div>

      {editingEntry && (
        <EditConfigModal
          entry={editingEntry}
          onCancel={() => setEditingEntry(null)}
          onSave={handleSave}
        />
      )}
    </div>
  );
}


